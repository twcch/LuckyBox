# Shared
APP_ENV=local
SERVER_PORT=8080

# Backend
LUCKYBOX_DB_URL=jdbc:sqlite:./data/luckybox-dev.sqlite?busy_timeout=5000
LUCKYBOX_DB_POOL_SIZE=1
LUCKYBOX_UPLOAD_DIR=./uploads
LUCKYBOX_UPLOAD_MAX_IMAGE_SIZE_BYTES=2097152
LUCKYBOX_SEED_ENABLED=true
LUCKYBOX_CSRF_ENABLED=true
LUCKYBOX_PAYMENT_MOCK_ENABLED=true
LUCKYBOX_PAYMENT_MOCK_WEBHOOK_SECRET=REPLACE_WITH_LOCAL_ONLY_SECRET
LUCKYBOX_APP_BASE_URL=http://localhost:5173
LUCKYBOX_MAIL_ENABLED=false
LUCKYBOX_MAIL_FROM=no-reply@luckybox.local
LUCKYBOX_DAILY_CHECK_IN_BONUS=20
LUCKYBOX_DAILY_CHECK_IN_STREAK_BONUSES=3:30,7:80,14:150,30:500
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
LUCKYBOX_RATELIMIT_ENABLED=true
LUCKYBOX_RATELIMIT_TRUST_FORWARDED_HEADERS=false

# Production readiness placeholders. Copy these to .env.production and uncomment.
# SPRING_PROFILES_ACTIVE=prod
# LUCKYBOX_PAYMENT_PROVIDER=ECPAY
# LUCKYBOX_PAYMENT_ECPAY_ENABLED=true
# LUCKYBOX_PAYMENT_ECPAY_MERCHANT_ID=REPLACE_WITH_ECPAY_MERCHANT_ID
# LUCKYBOX_PAYMENT_ECPAY_HASH_KEY=REPLACE_WITH_ECPAY_HASH_KEY
# LUCKYBOX_PAYMENT_ECPAY_HASH_IV=REPLACE_WITH_ECPAY_HASH_IV
# LUCKYBOX_PAYMENT_ECPAY_ACTION_URL=https://payment.ecpay.com.tw/Cashier/AioCheckOut/V5
# LUCKYBOX_PAYMENT_ECPAY_RETURN_URL=https://example.com/api/webhooks/payment/ecpay
# LUCKYBOX_PAYMENT_ECPAY_CLIENT_BACK_URL=https://example.com/account/orders
